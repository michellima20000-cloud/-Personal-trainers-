rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net catch-all-deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Helper to check if the current user is a registered trainer
    function isTrainer() {
      return isSignedIn() && exists(/databases/$(database)/documents/trainers/$(request.auth.uid));
    }

    // Helper to check if a student belongs to the current trainer
    function studentBelongsToTrainer(studentId) {
      let studentData = get(/databases/$(database)/documents/students/$(studentId)).data;
      return studentData.trainerUid == request.auth.uid || studentData.trainerId == request.auth.uid;
    }

    // 1. Students collection
    match /students/{studentId} {
      // Students can read their own profile. Trainers can read students linked to them.
      allow read: if isOwner(studentId) || (isSignedIn() && (resource.data.trainerUid == request.auth.uid || resource.data.trainerId == request.auth.uid || resource.data.email == request.auth.token.email));
      
      // Trainers can create or update students that belong to them.
      // Students can update their own profiles.
      allow create: if isSignedIn() && (isOwner(studentId) || request.resource.data.trainerUid == request.auth.uid || request.resource.data.trainerId == request.auth.uid || request.resource.data.email == request.auth.token.email);
      allow update: if isSignedIn() && (isOwner(studentId) || resource.data.trainerUid == request.auth.uid || resource.data.trainerId == request.auth.uid || request.resource.data.trainerUid == request.auth.uid || request.resource.data.trainerId == request.auth.uid || resource.data.email == request.auth.token.email);
      allow delete: if isSignedIn() && (resource.data.trainerUid == request.auth.uid || resource.data.trainerId == request.auth.uid);
    }

    // Duplicate path backup (legacy matching '/alunos/')
    match /alunos/{studentId} {
      allow read: if isOwner(studentId) || (isSignedIn() && (resource.data.trainerUid == request.auth.uid || resource.data.trainerId == request.auth.uid || resource.data.email == request.auth.token.email));
      allow create: if isSignedIn() && (isOwner(studentId) || request.resource.data.trainerUid == request.auth.uid || request.resource.data.trainerId == request.auth.uid || request.resource.data.email == request.auth.token.email);
      allow update: if isSignedIn() && (isOwner(studentId) || resource.data.trainerUid == request.auth.uid || resource.data.trainerId == request.auth.uid || request.resource.data.trainerUid == request.auth.uid || request.resource.data.trainerId == request.auth.uid || resource.data.email == request.auth.token.email);
      allow delete: if isSignedIn() && (resource.data.trainerUid == request.auth.uid || resource.data.trainerId == request.auth.uid);
    }

    // 2. Sheets collection
    match /sheets/{studentId} {
      // Students can read their own sheets. Trainers can read sheets of students linked to them.
      allow read: if isOwner(studentId) || (isSignedIn() && studentBelongsToTrainer(studentId));
      allow write: if isOwner(studentId) || (isSignedIn() && studentBelongsToTrainer(studentId));
    }

    // 3. Evolution subcollection under students
    match /students/{studentId}/evolution/{recordId} {
      allow read: if isOwner(studentId) || (isSignedIn() && studentBelongsToTrainer(studentId));
      allow write: if isOwner(studentId) || (isSignedIn() && studentBelongsToTrainer(studentId));
    }

    // 4. Chats subcollection under students
    match /students/{studentId}/chats/{messageId} {
      allow read: if isOwner(studentId) || (isSignedIn() && studentBelongsToTrainer(studentId));
      allow write: if isOwner(studentId) || (isSignedIn() && studentBelongsToTrainer(studentId));
    }

    // 5. Agenda collection
    match /agenda/{eventId} {
      // Trainers can read/write events. Students can only read/write their own events.
      allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || resource.data.trainerUid == request.auth.uid || resource.data.trainerId == request.auth.uid || isTrainer());
      allow write: if isSignedIn();
    }

    // 6. Notifications collection
    match /notifications/{notifId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // 7. Revenue logs
    match /revenueLogs/{month} {
      allow read, write: if isTrainer();
    }

    // 8. Access logs
    match /accessLogs/{logId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // 9. Marketing Plans
    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write: if isTrainer();
    }

    // 10. Trainers
    match /trainers/{trainerId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(trainerId);
      allow delete: if isOwner(trainerId);
    }
  }
}
